# ============================================================
# AI Office — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ----- Core -----
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret
LOG_LEVEL=INFO

# ----- LLM API Keys -----
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...            # Optional fallback

# ----- Database -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_office
POSTGRES_USER=ai_office
POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql://ai_office:changeme@postgres:5432/ai_office

# ----- Redis / Queue -----
REDIS_URL=redis://redis:6379/0

# ----- Vector DB -----
CHROMA_HOST=chromadb
CHROMA_PORT=8001
# For production: switch to Pinecone
# PINECONE_API_KEY=
# PINECONE_ENV=

# ----- Object Store (S3-compatible) -----
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-office-artifacts
S3_REGION=us-east-1

# ----- Orchestrator -----
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
MAX_DEBATE_ROUNDS=3
CONFIDENCE_THRESHOLD=0.75
ESCALATION_THRESHOLD=0.6
TASK_BUDGET_TOKENS=4000
AGENT_TIMEOUT_SECONDS=120

# ----- Adaptive Layer -----
ADAPTIVE_FAILURE_THRESHOLD=8
ADAPTIVE_WINDOW_SIZE=200
ADAPTIVE_CONFIDENCE_THRESHOLD=0.6
ADAPTIVE_AUTO_REGISTER=false    # true = auto-register low-impact agents

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=ai-office-orchestrator
